<% content_for :title, @subject.name %>

<%= render "shared/page_header",
      title: @subject.name,
      subtitle: "#{@subject.grade_level&.name || @subject.program&.name} · #{@subject.term}",
      actions: (can?("grades.write", @subject) ? ui_button("Registrar calificación", href: new_schedules_subject_grade_entry_path(@subject), variant: :primary) : nil) %>

<% if @enrollments.any? -%>
  <%= render layout: "shared/table",
        locals: { headers: ["Estudiante", "Calificaciones"] } do -%>
    <% @enrollments.each do |enrollment| -%>
      <tr>
        <td><%= "#{enrollment.student.first_name} #{enrollment.student.last_name}" %></td>
        <td>
          <% if enrollment.assessments.any? -%>
            <% enrollment.assessments.each do |assessment| -%>
              <%= assessment.title %> <%= grade_score_badge(assessment.score) %>
            <% end -%>
          <% else -%>
            Sin calificaciones
          <% end -%>
        </td>
      </tr>
    <% end -%>
  <% end -%>
<% else -%>
  <%= render "shared/empty_state", title: "Sin estudiantes matriculados" %>
<% end -%>
