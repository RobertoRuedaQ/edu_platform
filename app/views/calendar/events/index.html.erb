<% content_for :title, "Calendario" %>

<%= render "shared/page_header",
      title: "Calendario",
      subtitle: "Eventos dentro de tu alcance.",
      actions: ui_button("Nuevo evento", href: new_calendar_event_path, variant: :primary) %>

<% if @events.any? -%>
  <%= render layout: "shared/table",
        locals: { headers: [ "Inicio", "Título", "Audiencia", "" ] } do -%>
    <% @events.each do |event| -%>
      <tr>
        <td><%= event.starts_at.to_fs(:long) %></td>
        <td><%= event.title %></td>
        <td>
          <% if event.scope_group_id -%>
            Grupo: <%= event.group&.name || "—" %>
          <% elsif event.scope_grade_level_id -%>
            Grado: <%= event.grade_level&.name || "—" %>
          <% else -%>
            Toda la institución
          <% end -%>
        </td>
        <td><%= link_to "Editar", edit_calendar_event_path(event), class: "btn btn--secondary btn--sm" %></td>
      </tr>
    <% end -%>
  <% end -%>
<% else -%>
  <%= render "shared/empty_state",
        icon: "calendar",
        title: "No hay eventos en tu alcance",
        description: "Crea un evento para tu grupo, un grado o toda la institución." %>
<% end -%>
