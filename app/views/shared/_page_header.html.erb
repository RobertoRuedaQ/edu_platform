<%# locals: (title:, subtitle: nil, actions: nil) -%>
<%# actions: an html_safe string of buttons, e.g. ui_button("Nuevo", href: …) -%>
<header class="page-header">
  <div class="page-header__text">
    <h1 class="page-header__title"><%= title %></h1>
    <% if subtitle -%><p class="page-header__subtitle"><%= subtitle %></p><% end -%>
  </div>
  <% if actions -%><div class="page-header__actions"><%= actions %></div><% end -%>
</header>
