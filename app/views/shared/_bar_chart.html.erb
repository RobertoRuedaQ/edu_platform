<%# locals: (series:, title:, orientation: :vertical, unit: nil, id: nil, series_index: 1, **attrs) -%>
<%#
  Hand-rolled SVG bar chart (no charting library). Single series.
  series: array of { label:, value: } — already aggregated; no fetching here.
  Accessible: <figure> + role="img"/aria-labelledby, direct value labels (so
  identity is never color-alone), and a visually-hidden data table alternative.
  # TODO: reemplazar por vista materializada / agregado real.
-%>
<% series = Array(series) -%>
<% base = id.presence || "bar-#{title.to_s.parameterize}" -%>
<% max = [series.map { |p| p[:value].to_f }.max || 0, 1].max -%>
<% fmt = ->(v) { unit ? "#{v}#{unit}" : v.to_s } -%>
<% attrs[:class] = class_names("chart", attrs[:class]) -%>
<%= tag.figure(**attrs, "aria-labelledby": "#{base}-title") do -%>
  <figcaption class="chart__title" id="<%= base %>-title"><%= title %></figcaption>

  <% if orientation.to_sym == :horizontal -%>
    <% row = 34; label_w = 96; pad = 8; bar_h = 18; value_w = 44 -%>
    <% w = 360; plot_w = w - label_w - value_w; h = series.size * row + pad -%>
    <svg class="chart__svg" role="img" aria-labelledby="<%= base %>-title"
         viewBox="0 0 <%= w %> <%= h %>" preserveAspectRatio="xMinYMid meet">
      <% series.each_with_index do |p, i| -%>
        <% cy = i * row + row / 2 + pad / 2 -%>
        <% bw = (p[:value].to_f / max * plot_w).round(1) -%>
        <text class="chart__cat-label" x="<%= label_w - 8 %>" y="<%= cy %>" text-anchor="end" dominant-baseline="middle"><%= p[:label] %></text>
        <rect class="chart__bar" x="<%= label_w %>" y="<%= cy - bar_h / 2 %>" width="<%= [bw, 0.1].max %>" height="<%= bar_h %>" rx="4" fill="var(--chart-<%= series_index %>)"></rect>
        <text class="chart__value-label" x="<%= label_w + bw + 6 %>" y="<%= cy %>" dominant-baseline="middle"><%= fmt.call(p[:value]) %></text>
      <% end -%>
    </svg>

  <% else -%>
    <% slot = 56; bar_w = 30; pad_top = 22; pad_bottom = 28; plot_h = 176 -%>
    <% w = series.size * slot; h = pad_top + plot_h + pad_bottom; baseline = pad_top + plot_h -%>
    <svg class="chart__svg" role="img" aria-labelledby="<%= base %>-title"
         viewBox="0 0 <%= w %> <%= h %>" preserveAspectRatio="xMidYMid meet">
      <line class="chart__axis" x1="0" y1="<%= baseline %>" x2="<%= w %>" y2="<%= baseline %>"></line>
      <% series.each_with_index do |p, i| -%>
        <% cx = i * slot + slot / 2 -%>
        <% bh = (p[:value].to_f / max * plot_h).round(1) -%>
        <text class="chart__value-label" x="<%= cx %>" y="<%= baseline - bh - 6 %>" text-anchor="middle"><%= fmt.call(p[:value]) %></text>
        <rect class="chart__bar" x="<%= cx - bar_w / 2 %>" y="<%= (baseline - bh).round(1) %>" width="<%= bar_w %>" height="<%= [bh, 0.1].max %>" rx="4" fill="var(--chart-<%= series_index %>)"></rect>
        <text class="chart__cat-label" x="<%= cx %>" y="<%= h - 10 %>" text-anchor="middle"><%= p[:label] %></text>
      <% end -%>
    </svg>
  <% end -%>

  <table class="visually-hidden">
    <caption><%= title %></caption>
    <thead><tr><th scope="col">Categoría</th><th scope="col">Valor</th></tr></thead>
    <tbody>
      <% series.each do |p| -%><tr><td><%= p[:label] %></td><td><%= fmt.call(p[:value]) %></td></tr><% end -%>
    </tbody>
  </table>
<% end -%>
