<%# locals: (label:, name:, type: "text", value: nil, placeholder: nil, hint: nil, error: nil, required: false, **attrs) -%>
<%#
  Form field wrapper: label + input + hint + error, wired for accessibility
  (aria-invalid, aria-describedby). Works with plain params or a form object.
-%>
<% id = attrs.delete(:id) || "field-#{name.to_s.parameterize}" -%>
<% described_by = [(("#{id}-hint") if hint), (("#{id}-error") if error)].compact.join(" ") -%>
<div class="field <%= "field--invalid" if error %>">
  <label class="field__label" for="<%= id %>">
    <%= label %><% if required %><span class="field__req" aria-hidden="true"> *</span><% end %>
  </label>
  <%= tag.input(
        class: class_names("field__input", attrs.delete(:class)),
        id: id, name: name, type: type, value: value, placeholder: placeholder,
        required: required, "aria-invalid": (error ? "true" : nil),
        "aria-describedby": described_by.presence, **attrs) %>
  <% if hint -%><p class="field__hint" id="<%= id %>-hint"><%= hint %></p><% end -%>
  <% if error -%><p class="field__error" id="<%= id %>-error"><%= error %></p><% end -%>
</div>
