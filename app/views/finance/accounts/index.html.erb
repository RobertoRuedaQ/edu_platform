<% content_for :title, "Cartera" %>

<%= render "shared/page_header",
      title: "Cartera",
      subtitle: "Cuentas de estudiante dentro de tu alcance." %>

<% if @accounts.any? -%>
  <%= render layout: "shared/table",
        locals: { headers: [ "Estudiante", "Saldo", "" ] } do -%>
    <% @accounts.each do |account| -%>
      <tr>
        <td><%= "#{account.student.first_name} #{account.student.last_name}" %></td>
        <td class="finance-amount"><%= money(account.balance, currency: account.currency) %></td>
        <td><%= link_to "Ver cuenta", finance_account_path(account), class: "btn btn--secondary btn--sm" %></td>
      </tr>
    <% end -%>
  <% end -%>
<% else -%>
  <%= render "shared/empty_state",
        icon: "alert-circle",
        title: "No hay cuentas en tu alcance",
        description: "No ves cuentas fuera de las que tienes asignadas." %>
<% end -%>
