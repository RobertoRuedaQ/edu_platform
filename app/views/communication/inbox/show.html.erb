<% content_for :title, @conversation.subject %>

<%= render "shared/page_header",
      title: @conversation.subject,
      subtitle: (@conversation.active? ? "Activa" : "Cerrada #{@conversation.closed_at&.to_fs(:long)}"),
      actions: safe_join([
        (button_to "Cerrar", close_communication_inbox_path(@conversation), method: :post, class: "btn btn--secondary btn--sm" if @conversation.active?),
        (button_to "Reabrir", reopen_communication_inbox_path(@conversation), method: :post, class: "btn btn--secondary btn--sm" unless @conversation.active?)
      ].compact, " ") %>

<%= render "communication/message_thread", messages: @messages %>

<% if @conversation.active? -%>
  <%= form_with url: communication_inbox_messages_path(@conversation), method: :post do -%>
    <div class="field">
      <label class="field__label" for="body">Responder</label>
      <textarea class="field__input" id="body" name="body" rows="4"></textarea>
    </div>
    <%= ui_button "Enviar", type: "submit", variant: :primary %>
  <% end -%>
<% else -%>
  <%= render "shared/alert", variant: :info, message: "Esta conversación está cerrada. Reabrela para responder." %>
<% end -%>
