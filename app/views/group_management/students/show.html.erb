<% content_for :title, @student.name %>

<%= render "shared/page_header", title: @student.name, subtitle: @student.group_name %>

<%#
  Perfil y Matrícula son datos propios/cross-domain en stub (schedules).
  Convivencia/Acomodaciones son cross-domain en stub (student_support) —
  gateadas por su propio permiso, ausentes (no deshabilitadas) si el actor no
  lo tiene, igual que el resto de la nav.
-%>
<% panels = {} -%>

<% panels["Perfil"] = capture do %>
  <%= render "shared/detail_list", items: {
        "Código"   => @student.student_code,
        "Grupo"    => can?("groups.view") ? link_to(@student.group_name, group_management_group_path(@student.group_id)) : @student.group_name,
        "Grado"    => @student.grade_level_name,
        "Estado"   => student_status_badge(@student.status)
      } %>
<% end -%>

<% panels["Matrícula"] = capture do %>
  <%# Cross-domain (schedules) — TODO: reemplazar por Schedules::Enrollment real. %>
  <% if @student.enrollments.any? -%>
    <%= render layout: "shared/table", locals: { headers: ["Materia", "Periodo", "Estado"] } do -%>
      <% @student.enrollments.each do |enrollment| -%>
        <tr>
          <td><%= enrollment.subject %></td>
          <td><%= enrollment.term %></td>
          <td><%= ui_badge enrollment.status == "enrolled" ? "Matriculado" : enrollment.status.humanize,
                    variant: enrollment.status == "enrolled" ? :success : :neutral %></td>
        </tr>
      <% end -%>
    <% end -%>
  <% else -%>
    <%= render "shared/empty_state", title: "Sin materias matriculadas" %>
  <% end -%>
<% end -%>

<% if can?("disciplinary_logs.manage", @student) -%>
  <% panels["Convivencia"] = capture do %>
    <% logs = StudentSupport::DisciplinaryLogRoster.for_student(@student.id) -%>
    <% if logs.any? -%>
      <%= render "shared/timeline", items: logs.map { |log|
            { title: log.category.humanize, meta: datetime(log.occurred_at, format: :date), body: log.description }
          } %>
    <% else -%>
      <%= render "shared/empty_state", title: "Sin registros de convivencia" %>
    <% end -%>
    <%= ui_button "Ver convivencia completa", href: student_support_student_disciplinary_logs_path(@student.id),
          variant: :secondary, size: :sm %>
  <% end -%>
<% end -%>

<% if can?("accommodations.view", @student) -%>
  <% panels["Acomodaciones"] = capture do %>
    <% accommodations = StudentSupport::AccommodationRoster.for_student(@student.id).select { |a| a.status == "active" } -%>
    <% if accommodations.any? -%>
      <% accommodations.each do |accommodation| -%>
        <p><strong><%= accommodation.kind.humanize %>:</strong> <%= accommodation.description %></p>
      <% end -%>
    <% else -%>
      <%= render "shared/empty_state", title: "Sin acomodaciones vigentes" %>
    <% end -%>
    <%= ui_button "Ver acomodaciones", href: student_support_student_accommodations_path(@student.id),
          variant: :secondary, size: :sm %>
  <% end -%>
<% end -%>

<%= render "shared/tabs", panels: panels, id: "student-#{@student.id}", label: "Detalle del estudiante" %>
