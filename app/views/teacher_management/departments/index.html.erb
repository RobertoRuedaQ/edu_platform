<% content_for :title, "Departamentos" %>

<%= render "shared/page_header",
      title: "Departamentos",
      subtitle: "Departamentos dentro de tu alcance." %>

<% if @departments.any? -%>
  <%= render layout: "shared/table",
        locals: { headers: ["Departamento", "Tipo", "Docentes"] } do -%>
    <% @departments.each do |department| -%>
      <tr>
        <td><%= link_to department.name, teacher_management_department_path(department.id) %></td>
        <td><%= department.kind.humanize %></td>
        <td><%= @teacher_counts.fetch(department.id.to_s, 0) %></td>
      </tr>
    <% end -%>
  <% end -%>
<% else -%>
  <%= render "shared/empty_state",
        icon: "alert-circle",
        title: "No hay departamentos en tu alcance",
        description: "No ves departamentos fuera de tu institución." %>
<% end -%>
