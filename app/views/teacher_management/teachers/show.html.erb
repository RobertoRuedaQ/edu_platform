<% content_for :title, @teacher.name %>

<%= render "shared/page_header",
      title: @teacher.name,
      subtitle: @teacher.department_name %>

<% panels = {} -%>

<% panels["Perfil"] = capture do %>
  <%= render "shared/detail_list", items: {
        "Código"       => @teacher.teacher_code,
        "Departamento" => can?("departments.view") ? link_to(@teacher.department_name, teacher_management_department_path(@teacher.department_id)) : @teacher.department_name,
        "Estado"       => teacher_status_badge(@teacher.status)
      } %>

  <%= render "shared/stat", value: @teacher.group_ids.size.to_s, label: "grupos asignados" %>

  <h3>Cualificaciones</h3>
  <ul class="teacher-qualifications">
    <% @teacher.qualifications.each do |q| -%>
      <li><%= q %></li>
    <% end -%>
  </ul>
<% end -%>

<% panels["Evaluaciones"] = capture do %>
  <%# can? is cosmetic only — authorize! in TeacherEvaluationsController#new is the real gate. %>
  <%= render "shared/empty_state",
        icon: "alert-circle",
        title: "Sin evaluaciones registradas",
        description: "Este docente aún no tiene evaluaciones (stub).",
        action: (ui_button("Nueva evaluación", href: new_teacher_management_teacher_evaluation_path(@teacher)) if can?("teacher.evaluate", @teacher)) %>
<% end -%>

<%= render "shared/tabs", panels: panels, id: "teacher-#{@teacher.id}", label: "Detalle del docente" %>
