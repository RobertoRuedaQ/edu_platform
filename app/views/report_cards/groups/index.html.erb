<% content_for :title, "Boletines" %>

<%= render "shared/page_header",
      title: "Boletines",
      subtitle: "Grupos dentro de tu alcance." %>

<% if @groups.any? -%>
  <%= render layout: "shared/table",
        locals: { headers: [ "Grupo", "Grado", "" ] } do -%>
    <% @groups.each do |group| -%>
      <tr>
        <td><%= group.name %></td>
        <td><%= group.grade_level&.name || "—" %></td>
        <td><%= link_to "Ver boletines", new_report_cards_group_publication_path(group), class: "btn btn--secondary btn--sm" %></td>
      </tr>
    <% end -%>
  <% end -%>
<% else -%>
  <%= render "shared/empty_state",
        icon: "alert-circle",
        title: "No hay grupos en tu alcance",
        description: "No ves grupos fuera de los que tienes asignados." %>
<% end -%>
