<% content_for :title, "Carga de roster" %>

<% if @batch.status == "queued" -%>
  <%# No Turbo Streams/ActionCable here on purpose — that's OPEN_PROCESS.md
      item #2 ("Tiempo real"), gated separately on a real driver. A plain
      meta-refresh is enough to get the admin to a finished preview without
      building that infra ahead of time. %>
  <% content_for :head do %>
    <meta http-equiv="refresh" content="3">
  <% end %>
<% end -%>

<%= render "shared/page_header",
      title: "Carga de roster · #{@batch.created_at.to_fs(:long)}",
      subtitle: "Estado: #{@batch.status.humanize}",
      actions: (ui_button("Confirmar y aplicar", href: commit_identity_access_roster_import_path(@batch),
                  variant: :primary, data: { turbo_method: :post }) if @batch.status == "validated") %>

<% if @batch.status == "queued" -%>
  <%= render "shared/empty_state", title: "Procesando el archivo…",
        description: "El CSV se está parseando y validando. Esta página se actualiza sola." %>
<% else -%>
  <%= render "shared/stat", value: (@batch.summary["total_rows"] || 0).to_s, label: "filas" %>
  <%= render "shared/stat", value: (@batch.summary["create_count"] || 0).to_s, label: "a crear" %>
  <%= render "shared/stat", value: (@batch.summary["update_count"] || 0).to_s, label: "a actualizar" %>
  <%= render "shared/stat", value: ((@batch.summary["error_count"] || 0) + (@batch.summary["collision_count"] || 0)).to_s, label: "con error" %>

  <%# Never a browsable directory (privacy): only THIS batch's own
      just-uploaded rows, and every document number is masked, never shown in
      full — kind-agnostic, the columns/masking come entirely from the
      strategy (Core::RosterImport::Strategy.for), computed in the controller. %>
  <%= render layout: "shared/table",
        locals: { headers: ["Línea", *@preview_headers, "Acción", "Detalle"] } do -%>
    <% @previews.each do |row, columns| -%>
      <tr>
        <td><%= row.line_number %></td>
        <% columns.each do |value| -%>
          <td><%= value %></td>
        <% end -%>
        <td><%= roster_import_row_status_badge(row.status) %></td>
        <td><%= row.message %></td>
      </tr>
    <% end -%>
  <% end -%>
<% end -%>
