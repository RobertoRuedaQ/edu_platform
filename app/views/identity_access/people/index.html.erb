<% content_for :title, "Personas" %>

<%= render "shared/page_header", title: "Personas", subtitle: "Cuentas de tu institución.",
      actions: safe_join([
        ui_button("Cargar roster (CSV)", href: identity_access_roster_imports_path, variant: :secondary),
        ui_button("Nueva persona", href: new_identity_access_person_path, variant: :primary)
      ]) %>

<%= form_with url: identity_access_people_path, method: :get, class: "audit-filters" do -%>
  <div class="field">
    <label class="field__label" for="people-role">Rol de cuenta</label>
    <select class="field__input" id="people-role" name="role">
      <option value="">Todos</option>
      <% @roles.each do |role| -%>
        <option value="<%= role %>" <%= "selected" if params[:role] == role %>><%= role.humanize %></option>
      <% end -%>
    </select>
  </div>
  <div class="audit-filters__actions">
    <%= ui_button "Filtrar", type: "submit", variant: :primary %>
    <%= link_to "Limpiar", identity_access_people_path, class: "btn btn--secondary" %>
  </div>
<% end -%>

<% if @memberships.empty? -%>
  <%= render "shared/empty_state", title: "Todavía no hay personas registradas", icon: "users" %>
<% else -%>
  <%= render layout: "shared/table", locals: { headers: ["Nombre", "Correo", "Estado", "Invitación", ""] } do -%>
    <% @memberships.each do |membership| -%>
      <% invitation = @invitations_by_user[membership.user_id] -%>
      <tr>
        <td><%= membership.user.name %></td>
        <td><%= membership.user.email %></td>
        <td>
          <% if membership.active? -%>
            <%= render "shared/badge", label: "Activa", variant: :success %>
          <% else -%>
            <%= render "shared/badge", label: "Suspendida", variant: :danger %>
          <% end -%>
        </td>
        <td>
          <% if invitation.nil? -%>
            <%= render "shared/badge", label: "Sin invitar", variant: :neutral %>
          <% else -%>
            <%= render "shared/badge",
                  label: { "sent" => "Enviada", "completed" => "Completada", "expired" => "Vencida", "bounced" => "Rebotada" }.fetch(invitation.status, invitation.status),
                  variant: { "sent" => :info, "completed" => :success, "expired" => :warning, "bounced" => :danger }.fetch(invitation.status, :neutral) %>
          <% end -%>
        </td>
        <td>
          <div class="table-actions">
            <% if invitation.nil? || invitation.status != "completed" -%>
              <%= button_to "Reenviar invitación", resend_invitation_identity_access_person_path(membership), method: :post, class: "btn btn--secondary btn--sm" %>
            <% end -%>
            <% if membership.active? -%>
              <%= button_to "Suspender", suspend_identity_access_person_path(membership), method: :post, class: "btn btn--danger btn--sm" %>
            <% else -%>
              <%= button_to "Reactivar", reactivate_identity_access_person_path(membership), method: :post, class: "btn btn--secondary btn--sm" %>
            <% end -%>
            <% if can?("roles.manage") -%>
              <%= ui_button "Asignar rol", href: new_identity_access_assignment_path(user_id: membership.user_id), variant: :secondary, size: :sm %>
            <% end -%>
          </div>
        </td>
      </tr>
    <% end -%>
  <% end -%>
<% end -%>
