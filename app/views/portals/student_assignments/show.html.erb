<% content_for :title, @assignment.title %>

<%= render "shared/page_header",
      title: @assignment.title,
      subtitle: "#{@assignment.subject.name} · vence #{@assignment.due_date}",
      actions: ui_button("← Volver", href: portal_student_assignments_path, variant: :secondary) %>

<% if @assignment.instructions.present? -%>
  <p><%= simple_format(@assignment.instructions) %></p>
<% end -%>

<%= render "shared/detail_list", items: {
      "Nota" => (Assignments::StudentView.score_for(@assignment, @student) || "Pendiente")
    } %>

<%= render "assignments/submission_form", submission: @submission,
      url: portal_student_assignment_submission_path(@assignment) %>
