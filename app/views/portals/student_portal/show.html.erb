<% content_for :title, "Mi portal" %>

<%= render "shared/page_header",
      title: "Hola, #{@portal_person_name}",
      subtitle: "Tu resumen.",
      actions: safe_join([
        ui_button("Anuncios", href: portal_student_announcements_path, variant: :secondary),
        ui_button("Tareas", href: portal_student_assignments_path, variant: :secondary),
        (ui_button("Mis boletines", href: portal_student_report_cards_path, variant: :secondary) if @student),
        (ui_button("Asistencia", href: portal_student_attendance_path, variant: :secondary) if @student),
        (ui_button("Calendario", href: portal_student_calendar_path, variant: :secondary) if @student),
        (ui_button("Actividades", href: portal_student_activities_path, variant: :secondary) if @student),
        (ui_button("Mi ficha de carácter", href: portal_student_character_card_path, variant: :secondary) if @student)
      ].compact, " ") %>

<% if @student -%>
  <%# Read-only (GS8): no forms here. national_id is never shown (privacy). %>
  <%= render "shared/detail_list", items: {
        "Código" => @student.student_code,
        "Grado" => @student.grade_level&.name,
        "Grupo" => @student.section&.name,
        # Descriptive label ONLY (GS3) — see Portals::GuardianStudentsController's
        # equivalent for the same non-filtering rationale.
        "Término activo" => Core::AcademicTerm.active.find_by(institution_id: Current.institution_id)&.name
      } %>
<% else -%>
  <%= render "shared/empty_state",
        icon: "user",
        title: "Tu cuenta aún no está vinculada a un registro de estudiante",
        description: "Si esto no es lo esperado, contacta a tu institución." %>
<% end -%>
