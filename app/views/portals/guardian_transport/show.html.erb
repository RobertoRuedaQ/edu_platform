<% content_for :title, "Transporte" %>

<% @children.each do |child| -%>
  <h3><%= child.first_name %> <%= child.last_name %></h3>
  <% riders = @riders_by_child[child] -%>
  <% if riders.any? -%>
    <% riders.each do |rider| -%>
      <%= render "shared/detail_list", items: {
            "Turno"  => rider.shift_label,
            "Ruta"   => rider.route.name,
            "Parada" => rider.stop_name || "—"
          } %>
    <% end -%>
  <% else -%>
    <%= render "shared/empty_state", title: "Sin ruta asignada" %>
  <% end -%>
<% end -%>
