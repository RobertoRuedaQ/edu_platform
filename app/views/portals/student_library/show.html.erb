<% content_for :title, "Biblioteca" %>

<%= render "shared/page_header", title: "Biblioteca", subtitle: "Tus préstamos y el catálogo disponible." %>

<h3>Mis préstamos</h3>
<% if @loans.any? -%>
  <%= render layout: "shared/table", locals: { headers: ["Título", "Prestado", "Vence", "Estado"] } do -%>
    <% @loans.each do |loan| -%>
      <tr>
        <td><%= loan.copy.resource.title %></td>
        <td><%= loan.borrowed_at.strftime("%d/%m/%Y") %></td>
        <td><%= loan.due_at.strftime("%d/%m/%Y") %></td>
        <td>
          <% if loan.overdue? -%>
            <%= ui_badge "Vencido", variant: :danger %>
          <% else -%>
            <%= ui_badge loan.status.humanize, variant: (loan.status == "active" ? :warning : :success) %>
          <% end -%>
        </td>
      </tr>
    <% end -%>
  <% end -%>
<% else -%>
  <%= render "shared/empty_state", title: "Sin préstamos activos", description: "No tienes libros prestados en este momento." %>
<% end -%>

<h3>Catálogo disponible</h3>
<%= render layout: "shared/table", locals: { headers: ["Título", "Autor", "Categoría"] } do -%>
  <% @catalog.each do |resource| -%>
    <tr>
      <td><%= resource.title %></td>
      <td><%= resource.author %></td>
      <td><%= resource.dewey_category %></td>
    </tr>
  <% end -%>
<% end -%>
