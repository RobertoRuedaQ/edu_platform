<%# locals: (name:, employee_number:, category:, employment_type:, status:, department: nil) -%>
<%# A <tr> for a staff directory rendered inside shared/_table. -%>
<% status_variant = { "active" => :success, "on_leave" => :warning, "terminated" => :neutral }.fetch(status.to_s, :neutral) -%>
<% status_label = { "active" => "Activo", "on_leave" => "En licencia", "terminated" => "Desvinculado" }.fetch(status.to_s, status.to_s.humanize) -%>
<tr>
  <td>
    <span class="staff-row__person">
      <%= ui_avatar name, size: :sm %>
      <span><%= name %></span>
    </span>
  </td>
  <td><%= employee_number %></td>
  <td><%= render "staff_management/employment_badge", category: category, employment_type: employment_type %></td>
  <td><%= department.presence || "—" %></td>
  <td><%= ui_badge status_label, variant: status_variant %></td>
</tr>
