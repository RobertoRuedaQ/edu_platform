<% content_for :title, "Personal" %>

<%= render "shared/page_header", title: "Personal", subtitle: "Personal no docente de la institución." %>

<%= render layout: "shared/table",
      locals: { headers: ["Persona", "N.º empleado", "Categoría", "Departamento", "Estado"] } do -%>
  <% @staff.each do |member| -%>
    <%= render "staff_management/staff_directory_row",
          name: member.name, employee_number: member.employee_number, category: member.category,
          employment_type: member.employment_type, status: member.status, department: member.department %>
  <% end -%>
<% end -%>
