#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

FileUtils.chdir APP_ROOT do
  # This script sets up or updates your development environment. It is idempotent,
  # so you can run it at any time and get an expectable outcome.

  puts "== Installing dependencies =="
  system("bundle check") || system!("bundle install")

  puts "\n== Creating databases (as the local superuser) =="
  # db:create needs a role that can CREATE DATABASE. In dev that's your local
  # superuser (the default connection), NOT edu_app_runtime.
  system! "bin/rails db:create"

  puts "\n== Creating PostgreSQL roles (idempotent; needs CREATEROLE) =="
  # Reads EDU_*_PASSWORD from ENV. Run by the superuser/DBA.
  system! "bin/rails db:roles:create"

  puts "\n== Preparing schema AS THE MIGRATOR (never as app_runtime) =="
  migrator_env = {
    "EDU_DB_USER"     => ENV.fetch("EDU_MIGRATOR_USER", "edu_migrator"),
    "EDU_DB_PASSWORD" => ENV.fetch("EDU_MIGRATOR_PASSWORD")
  }
  # db:prepare loads the Solid schemas and runs any pending migrations.
  system!(migrator_env, "bin/rails db:prepare")

  puts "\n== Provisioning a development institution =="
  # Guarded: the institutions table arrives in the table-migration phase. Until
  # then this is a no-op, so bin/setup is runnable today and complete later.
  system! %(bin/rails runner '
    if ActiveRecord::Base.connection.table_exists?(:institutions)
      Provisioning::CreateInstitution.call(name: "Demo Academy", slug: "demo", code: "DEMO") \
        unless Core::Institution.exists?(slug: "demo")
      puts "Provisioned tenant: demo"
    else
      puts "Skipping tenant provisioning - institutions table not created yet."
    end
  ')

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  unless ARGV.include?("--skip-server")
    puts "\n== Starting development server =="
    STDOUT.flush # flush the output before exec(2) so that it displays
    exec "bin/dev"
  end
end
